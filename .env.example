ENV_STATE=local
DEBUG=true

# DATABASE CONNECTION
DATABASE_URL=postgresql+asyncpg://{postgres_user}:{postgres_password}@{hostname}:{port}/db_name
POSTGRES_USER=postgres_username
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=db_name
POOL_SIZE=5
MAX_OVERFLOW=10
POOL_TIMEOUT=30
POOL_RECYCLE=3600
POOL_PRE_PING=true

# SECURITY
SECRET_KEY=my_very_secret_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
